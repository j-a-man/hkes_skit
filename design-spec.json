{
  "meta": {
    "name": "Death Note — How to Use It",
    "description": "UI design specification for replicating the Death Note rule page",
    "stack": ["Next.js 14", "Tailwind CSS v3", "Framer Motion v11"],
    "page": "I"
  },

  "theme": {
    "colors": {
      "background": "#000000",
      "text": "#FFFFFF",
      "border": "#FFFFFF",
      "ornament": "#FFFFFF",
      "glow": "rgba(255,255,255,0.25)"
    },
    "fonts": {
      "title": {
        "family": "Pirata One",
        "source": "Google Fonts",
        "fallback": "cursive",
        "weight": "400",
        "letterSpacing": "0.06em",
        "textTransform": "uppercase",
        "size": "clamp(2.8rem, 8vw, 5rem)"
      },
      "subtitle": {
        "family": "Uncial Antiqua",
        "source": "Google Fonts",
        "fallback": "cursive",
        "weight": "400",
        "style": "italic",
        "size": "1.4rem"
      },
      "sectionNumber": {
        "family": "Uncial Antiqua",
        "source": "Google Fonts",
        "fallback": "cursive",
        "weight": "400",
        "size": "1.2rem",
        "textAlign": "center"
      },
      "ruleEnglish": {
        "family": "Special Elite",
        "source": "Google Fonts",
        "fallback": "cursive",
        "weight": "400",
        "style": "italic",
        "size": "1.05rem",
        "lineHeight": "1.45"
      },
      "ruleJapanese": {
        "family": "Noto Sans JP",
        "source": "Google Fonts",
        "fallback": "sans-serif",
        "weight": "400",
        "size": "0.65rem",
        "lineHeight": "1.7"
      }
    }
  },

  "layout": {
    "page": {
      "backgroundColor": "#000000",
      "minHeight": "100vh",
      "display": "flex",
      "alignItems": "center",
      "justifyContent": "center",
      "padding": "60px 20px"
    },
    "frame": {
      "maxWidth": "680px",
      "width": "100%",
      "position": "relative",
      "border": "2px solid #FFFFFF",
      "outline": "1px solid #FFFFFF",
      "outlineOffset": "-10px",
      "padding": "48px 40px 36px",
      "backgroundColor": "#000000"
    }
  },

  "components": {
    "skullMedallion": {
      "description": "Circular skull emblem with sunburst spikes, centered at top of frame",
      "position": "absolute",
      "top": "-52px",
      "left": "50%",
      "transform": "translateX(-50%)",
      "size": {
        "width": "96px",
        "height": "96px"
      },
      "outerCircle": {
        "diameter": "96px",
        "border": "2px solid #FFFFFF",
        "borderRadius": "50%",
        "backgroundColor": "#000000"
      },
      "innerSkull": {
        "size": "52px",
        "color": "#FFFFFF",
        "centered": true
      },
      "sunburst": {
        "spokeCount": 24,
        "innerRadius": "52px",
        "outerRadius": "64px",
        "strokeColor": "#FFFFFF",
        "strokeWidth": "1.5px"
      },
      "glow": "0 0 18px rgba(255,255,255,0.3)",
      "animation": {
        "type": "pulse",
        "scale": [1, 1.04, 1],
        "duration": "3s",
        "repeat": "Infinity",
        "ease": "easeInOut"
      }
    },

    "cornerOrnaments": {
      "description": "Baroque scroll ornaments at each corner inside the frame border",
      "size": "64px",
      "color": "#FFFFFF",
      "positions": [
        { "corner": "top-left",     "top": "-2px",  "left": "-2px",  "rotate": "0deg"    },
        { "corner": "top-right",    "top": "-2px",  "right": "-2px", "rotate": "90deg"   },
        { "corner": "bottom-right", "bottom": "-2px","right": "-2px", "rotate": "180deg"  },
        { "corner": "bottom-left",  "bottom": "-2px","left": "-2px",  "rotate": "270deg"  }
      ],
      "svgPath": "M4,4 C4,4 20,4 30,14 C40,24 44,44 60,56 C44,44 24,40 14,30 C4,20 4,4 4,4Z"
    },

    "header": {
      "textAlign": "center",
      "marginBottom": "28px",
      "title": {
        "text": "DEATH NOTE",
        "font": "title",
        "color": "#FFFFFF",
        "specialGlyphs": [
          { "char": "A", "in": "DEATH", "overlay": "dagger-cross" },
          { "char": "O", "in": "NOTE",  "overlay": "cross"        }
        ],
        "marginBottom": "4px"
      },
      "subtitle": {
        "text": "How to use it",
        "font": "subtitle",
        "color": "#FFFFFF",
        "transform": "rotate(-1deg)",
        "marginBottom": "4px"
      },
      "sectionNumber": {
        "text": "I",
        "font": "sectionNumber",
        "color": "#FFFFFF"
      }
    },

    "rulesList": {
      "listStyle": "none",
      "padding": "0",
      "margin": "0",
      "gap": "20px"
    },

    "ruleItem": {
      "display": "flex",
      "flexDirection": "column",
      "gap": "6px",
      "bullet": {
        "character": "◦",
        "font": "ruleEnglish",
        "color": "#FFFFFF",
        "marginRight": "6px",
        "verticalAlign": "top"
      },
      "englishText": {
        "font": "ruleEnglish",
        "color": "#FFFFFF",
        "display": "inline"
      },
      "japaneseText": {
        "font": "ruleJapanese",
        "color": "#FFFFFF",
        "paddingLeft": "16px",
        "marginTop": "4px",
        "useRubyTags": true
      }
    }
  },

  "content": {
    "rules": [
      {
        "id": 1,
        "english": "The human whose name is written in this note shall die.",
        "japanese": {
          "text": "このノートに名前を書かれた人間は死ぬ。",
          "furigana": []
        }
      },
      {
        "id": 2,
        "english": "This note will not take effect unless the writer has the person's face in their mind when writing his/her name. Therefore, people sharing the same name will not be affected.",
        "japanese": {
          "text": "書く人物の顔が頭に入っていないと効果はない。ゆえに同姓同名の人物に一遍に効果は得られない。",
          "furigana": [
            { "base": "書く",     "reading": "か"      },
            { "base": "人物",     "reading": "じんぶつ" },
            { "base": "顔",       "reading": "かお"    },
            { "base": "頭",       "reading": "あたま"  },
            { "base": "効果",     "reading": "こうか"  },
            { "base": "同姓同名", "reading": "どうせいどうめい" },
            { "base": "一遍",     "reading": "いっぺん" }
          ]
        }
      },
      {
        "id": 3,
        "english": "If the cause of death is written within 40 seconds of writing the person's name, it will happen.",
        "japanese": {
          "text": "名前の後に人間界単位で40秒以内に死因を書くと、その通りになる。",
          "furigana": [
            { "base": "名前",   "reading": "なまえ"      },
            { "base": "後",     "reading": "あと"        },
            { "base": "人間界", "reading": "にんげんかい" },
            { "base": "単位",   "reading": "たんい"      },
            { "base": "以内",   "reading": "いない"      },
            { "base": "死因",   "reading": "しいん"      },
            { "base": "書く",   "reading": "か"          },
            { "base": "通り",   "reading": "とお"        }
          ]
        }
      },
      {
        "id": 4,
        "english": "If the cause of death is not specified, the person will simply die of a heart attack.",
        "japanese": {
          "text": "死因を書かなければ全てが心臓麻痺となる。",
          "furigana": [
            { "base": "死因",   "reading": "しいん"    },
            { "base": "書か",   "reading": "か"        },
            { "base": "全て",   "reading": "すべ"      },
            { "base": "心臓麻痺","reading": "しんぞうまひ" }
          ]
        }
      },
      {
        "id": 5,
        "english": "After writing the cause of death, details of the death should be written in the next 6 minutes and 40 seconds.",
        "japanese": {
          "text": "死因を書くと更に6分40秒、詳しい死の状況を記載する時間が与えられる。",
          "furigana": [
            { "base": "死因",   "reading": "しいん"   },
            { "base": "書く",   "reading": "か"       },
            { "base": "更に",   "reading": "さら"     },
            { "base": "詳しい", "reading": "くわ"     },
            { "base": "死",     "reading": "し"       },
            { "base": "状況",   "reading": "じょうきょう" },
            { "base": "記載",   "reading": "きさい"   },
            { "base": "時間",   "reading": "じかん"   },
            { "base": "与えられる","reading": "あた"  }
          ]
        }
      }
    ]
  },

  "animations": {
    "pageEntrance": {
      "type": "fadeIn",
      "initial": { "opacity": 0 },
      "animate": { "opacity": 1 },
      "transition": { "duration": 1.2, "ease": "easeIn" }
    },
    "skullEntrance": {
      "type": "scaleAndFade",
      "initial": { "opacity": 0, "scale": 0.6 },
      "animate": { "opacity": 1, "scale": 1 },
      "transition": { "delay": 0.3, "duration": 0.8, "ease": "easeOut" }
    },
    "borderEntrance": {
      "type": "clipPathWipe",
      "initial": { "clipPath": "inset(50% 50% 50% 50%)" },
      "animate": { "clipPath": "inset(0% 0% 0% 0%)" },
      "transition": { "delay": 0.5, "duration": 1.0, "ease": "easeOut" }
    },
    "titleEntrance": {
      "type": "staggerLetters",
      "initial": { "opacity": 0, "y": -20 },
      "animate": { "opacity": 1, "y": 0 },
      "staggerChildren": 0.04,
      "transition": { "delay": 0.8, "duration": 0.5 }
    },
    "rulesEntrance": {
      "type": "staggerItems",
      "initial": { "opacity": 0, "y": 24 },
      "animate": { "opacity": 1, "y": 0 },
      "staggerChildren": 0.18,
      "transition": { "delay": 1.4, "duration": 0.6, "ease": "easeOut" }
    },
    "skullPulse": {
      "type": "loop",
      "animate": { "scale": [1, 1.04, 1] },
      "transition": { "duration": 3, "repeat": "Infinity", "ease": "easeInOut" }
    }
  },

  "responsive": {
    "breakpoints": {
      "sm": "640px",
      "md": "768px"
    },
    "mobile": {
      "framePadding": "32px 24px 28px",
      "titleFontSize": "2.2rem",
      "ruleFontSize": "0.95rem",
      "japaneseFontSize": "0.6rem"
    }
  },

  "extras": {
    "customCursor": {
      "enabled": true,
      "style": "crosshair",
      "note": "Optional: override with a skull SVG cursor via CSS cursor: url(skull.cur)"
    },
    "pageTitle": "Death Note — How To Use It",
    "htmlLang": "ja",
    "metaThemeColor": "#000000"
  }
}
